DATABASE_URL="file:./dev.db"
STORAGE_DIR="./storage"

# Provider API Key 静态加密主密钥（base64 的 32 字节）。
# 生成：openssl rand -base64 32
# 设置后保存的 provider Key 会以 AES-256-GCM 加密入库；存量明文用 `pnpm db:encrypt-secrets` 迁移。
PROVIDER_KEY_ENCRYPTION_KEY=""

# worker 并发处理上限（1..12，默认 3）：并发重叠 AI HTTP 等待以提升吞吐。
WORKER_CONCURRENCY="3"

# 超过该毫秒数仍为 active 的 job 视为孤儿（worker 崩溃残留），由 reaper 重置回 queued（默认 300000）。
WORKER_STALE_JOB_MS="300000"

# PDF 转图片的渲染倍率（pdfjs 按 72DPI × scale 栅格化，输出 PNG 无损编码）。
# PDF 转图片必然要栅格化，无法 100% 无损；倍率越高越逼近无损、越清晰，但单页体积/耗时/内存也越大。
# 默认 4（≈288DPI，偏「尽量无损」）；取值范围 1..6（6≈432DPI），非法值回退默认。
PDF_RENDER_SCALE="4"
