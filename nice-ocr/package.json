{
  "name": "nice-ocr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "worker": "prisma db push --skip-generate && tsx scripts/worker.ts",
    "db:generate": "prisma generate",
    "db:backfill-provider-models": "tsx scripts/backfill-provider-models.ts",
    "db:backfill-source-region": "tsx scripts/backfill-source-region.ts",
    "db:migrate": "tsx scripts/backfill-provider-models.ts && prisma migrate dev",
    "db:push": "tsx scripts/backfill-provider-models.ts && prisma db push --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "db:encrypt-secrets": "tsx scripts/encrypt-secrets.ts",
    "test": "tsx scripts/test.ts",
    "test:raw": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "fflate": "^0.8.3",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "openai": "^6.42.0",
    "pdf-to-img": "^6.2.0",
    "pdfjs-dist": "5.6.205",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
